    <div class="code-card">
      <div class="code-header">
        <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
        <span class="code-filename">allxone.config.ts</span>
      </div>
      <pre class="code-body"><code><span class="c-kw">export const</span> <span class="c-fn">config</span> = &#123;
  <span class="c-key">services</span>: [
    <span class="c-str">"Software Dev"</span>,
    <span class="c-str">"Cloud & AI"</span>,
    <span class="c-str">"Blockchain"</span>,
    <span class="c-str">"IT Staffing"</span>,
  ],
  <span class="c-key">mindset</span>: <span class="c-str">"Service First"</span>,
  <span class="c-key">location</span>: <span class="c-str">"HCM City 🇻🇳"</span>,
  <span class="c-key">quality</span>: <span class="c-str">"Excellence"</span>,
&#125;</code></pre>
    </div>
    <div class="float-card fc-1">
      <span class="fc-icon">⚡</span>
      <div>
